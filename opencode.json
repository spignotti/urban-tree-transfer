{
  "$schema": "https://opencode.ai/config.json",
  "watcher": {
    "ignore": [
      ".venv/**",
      ".nox/**",
      ".pytest_cache/**",
      ".ruff_cache/**",
      ".pyright/**",
      "build/**",
      "dist/**",
      "htmlcov/**",
      "*.egg-info/**"
    ]
  },
  "mcp": {
    "context7": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "@upstash/context7-mcp"
      ],
      "environment": {
        "CONTEXT7_API_KEY": "${CONTEXT7_API_KEY}"
      }
    }
  }
}
